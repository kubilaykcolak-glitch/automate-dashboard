rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/files/{filePath=**} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
