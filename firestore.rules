rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false; // writes that change billing state must go through Admin SDK

      // Encrypted OAuth tokens — Admin SDK only. The client must never see
      // these, even though they're encrypted at rest as defense in depth.
      match /integration_tokens/{docId} {
        allow read, write: if false;
      }

      // Per-user data the client owns: agents, integrations, files, activity, etc.
      // This wildcard runs after the explicit token rule above, so token docs
      // remain locked even though they live under a users/{uid}/* path.
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
    // /workspaces was a planned multi-tenant collection that never got built.
    // No app code reads or writes it. Removed during audit to keep the rules
    // file an accurate inventory of what actually exists.
  }
}
